# JARVIS v5.0 Persistent Server Configuration

# 포트 설정
PORT=3001

# Vercel 프론트엔드 URL
VERCEL_FRONTEND_URL=https://your-vercel-domain.vercel.app

# 네이버 계정 (선택사항 - 자동 로그인용)
NAVER_EMAIL=your-email@naver.com
NAVER_PASSWORD=your-password

# Google Gemini API (시장 분석용)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# KAMIS API (농산물 가격 정보)
KAMIS_API_KEY=your-kamis-api-key

# 자동화 스케줄 (cron 형식)
RESERVATION_SCHEDULE=0 9 * * *
MARKETING_SCHEDULE=0 */6 * * *

# 로깅 레벨
LOG_LEVEL=info

# 디버그 모드
DEBUG=false
